OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=300
OPENAI_TEMPERATURE_CLASSIFY=0.0
OPENAI_TEMPERATURE_SUMMARIZE=0.2
OPENAI_TEMPERATURE_EXTRACT_KEYWORDS=0.0
OPENAI_TEMPERATURE_TRANSLATE=0.1
OPENAI_TEMPERATURE_ANALYZE_TEXT=0.0
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_DELAY_SECONDS=0.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=documents
DOCUMENT_CHUNK_SIZE=500
DOCUMENT_CHUNK_OVERLAP=100
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.2
RAG_TEMPERATURE=0.1
RAG_MAX_TOKENS=500
PROMPT_ASK_SYSTEM="You are a helpful assistant. Give clear and concise answers."
PROMPT_ASK_STREAM_SYSTEM="You are a helpful assistant. Stream clear and concise answers."
PROMPT_CLASSIFY_SYSTEM="You are a precise sentiment classifier. Return only valid JSON that matches the schema."
PROMPT_SUMMARIZE_SYSTEM="You summarize text in 2-3 short, clear sentences."
PROMPT_EXTRACT_KEYWORDS_SYSTEM="Extract the most relevant keywords from the text. Return only valid JSON that matches the schema."
PROMPT_TRANSLATE_SYSTEM="You are a professional translator. Return only the translated text without extra commentary."
PROMPT_ANALYZE_TEXT_SYSTEM="You are an NLP assistant. Analyze user text and return valid JSON. Include summary, sentiment (positive|negative|neutral), keywords list, and detected language."
PROMPT_TOOL_ASSISTANTPROMPT_TOOL_ASSISTANT_SYSTEM_SYSTEM="You are a safe tool-calling assistant. Use tools only when they help. Never claim that a ticket was filed or an email was sent; ticket and email tools only create drafts that require human confirmation. Summarize tool results clearly for the user."
PROMPT_RAG_SYSTEM="You are a documentation assistant. Answer the user's question using ONLY the numbered context snippets provided. Cite the snippets you rely on with bracketed numbers like [1] or [2]. If the answer is not contained in the context, reply that you don't know based on the provided documents. Never invent facts that are not supported by the context."
